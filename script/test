#!/usr/bin/env bash

set -euo pipefail

echo "building niv"

nix build .#niv --no-link

echo "running checks"

nix flake check --print-build-logs --max-jobs 1

echo "checking README"

readme=$(mktemp)
gen_readme_cmd='cat $(nix build .#readme --no-link --print-out-paths) >'
eval "$gen_readme_cmd $readme" # generates the readme to "$readme"
exitcode=0
if ! diff "$readme" ./README.md; then
    echo please run
    echo "    '$gen_readme_cmd README.md'"
    exitcode=1
fi
rm "$readme"

exit "$exitcode"
